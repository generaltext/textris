{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["react"],
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "off",
    "eqeqeq": "error",
    "react/rules-of-hooks": "error",
    "react/exhaustive-deps": "error",
    "react/hook-use-state": "error"
  },
  "ignorePatterns": ["node_modules", "dist"]
}
